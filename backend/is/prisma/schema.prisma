generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model legal_form {
  code         String         @id @db.VarChar(10) // napr. "706"
  name         String         @db.VarChar(150)    // napr. "Spolek"
  
  organization organization[]
}

model size_category {
  code         String         @id @db.VarChar(10) // napr. "120"
  label        String         @db.VarChar(50)     // napr. "1 - 5 zaměstnanců"
  min_emp      Int?
  max_emp      Int?
  
  organization organization[]
}

model branch {
  branch_id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String? @db.Uuid
  city            String? @db.VarChar(100)
  street          String? @db.VarChar(150)
  email           String? @db.VarChar(120)
  tel_num         String? @db.VarChar(30)
  lat             Float?
  lon             Float?

  organization organization? @relation(fields: [organization_id], references: [organization_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organization_id, lat, lon], map: "uq_branch_org_lat_lon")
}

model category {
  category_id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String?                 @unique(map: "category_name_unique") @db.VarChar(100)
  organization_category organization_category[]
}

model data_source {
  source_id    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String         @db.VarChar(100)
  url          String
  last_scraped DateTime?      @db.Timestamp(6)
  organization organization[]
}

model npo_manager {
  user_id         String @db.Uuid
  organization_id String @db.Uuid
  user            user   @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([user_id, organization_id])
}

model organization {
  organization_id    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_id          String?        @db.Uuid
  parent_id          String?        @db.Uuid
  name               String         @db.VarChar(200)
  ico                String         @unique @db.VarChar(20)
  web_url            String?
  created_at         DateTime       @db.Timestamp(6)
  hq_address         String?
  lat                Float?
  lon                Float?
  description        String?
  emails             String[]       @db.VarChar(120)
  tel_numbers        String[]       @db.VarChar(30)

  legal_form_code    String?        @db.VarChar(10)
  size_category_code String?        @db.VarChar(10)

  legal_form_rel     legal_form?    @relation(fields: [legal_form_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  size_category_rel  size_category? @relation(fields: [size_category_code], references: [code], onDelete: NoAction, onUpdate: NoAction)

  organization       organization?  @relation("organizationToorganization", fields: [parent_id], references: [organization_id], onDelete: NoAction, onUpdate: NoAction)
  other_organization organization[] @relation("organizationToorganization")
  data_source        data_source?   @relation(fields: [source_id], references: [source_id], onDelete: NoAction, onUpdate: NoAction)

  organization_category organization_category[]
  branches              branch[]
}

model organization_category {
  organization_id String   @db.Uuid
  category_id     String   @db.Uuid
  category        category @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)

  organization    organization @relation(fields: [organization_id], references: [organization_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([organization_id, category_id])
}

model role {
  role_id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @db.VarChar(50)
  description String?
}

model user {
  user_id       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(100)
  email         String        @unique @db.VarChar(120)
  password_hash String
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  npo_manager   npo_manager[]
}
